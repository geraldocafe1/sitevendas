<div class="space-y-6 font-body">
  
  <div class="flex items-center justify-between">
    <p class="text-xs text-text-muted">Crie e configure cupons de desconto para a Grão Nobre.</p>
    <button type="button" 
            onclick="openAddCouponModal()"
            class="px-4 py-2 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors flex items-center space-x-1.5">
      <span>+ Novo Cupom</span>
    </button>
  </div>

  <!-- Coupons Table list -->
  <div class="bg-white border border-border rounded-2xl overflow-hidden shadow-xs">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-xs">
        <thead>
          <tr class="bg-surface text-text-muted font-bold border-b border-border">
            <th class="p-4">Código</th>
            <th class="p-4">Tipo</th>
            <th class="p-4 text-right">Valor</th>
            <th class="p-4 text-right">Mín. Pedido</th>
            <th class="p-4 text-center">Usos</th>
            <th class="p-4 text-center">Vencimento</th>
            <th class="p-4 text-center">Status</th>
            <th class="p-4 text-center w-28">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (coupons && coupons.length > 0) { %>
            <% coupons.forEach(coup => { %>
              <tr class="<%= !coup.is_active ? 'bg-gray-50 opacity-60' : '' %>">
                <td class="p-4 font-mono font-bold text-primary tracking-wide"><%= coup.code %></td>
                <td class="p-4 text-text-muted">
                  <%= coup.type === 'percent' ? 'Porcentagem' : 'Valor Fixo' %>
                </td>
                <td class="p-4 text-right font-bold">
                  <%= coup.type === 'percent' ? `${parseFloat(coup.value).toFixed(0)}%` : `R$ ${parseFloat(coup.value).toFixed(2).replace('.', ',')}` %>
                </td>
                <td class="p-4 text-right text-text-muted">
                  R$ <%= parseFloat(coup.min_order_value).toFixed(2).replace('.', ',') %>
                </td>
                <td class="p-4 text-center font-semibold">
                  <%= coup.used_count %> <%= coup.max_uses ? `/ ${coup.max_uses}` : '' %>
                </td>
                <td class="p-4 text-center text-text-muted">
                  <%= coup.expires_at ? new Date(coup.expires_at).toLocaleDateString('pt-BR') : '---' %>
                </td>
                <td class="p-4 text-center">
                  <span class="px-2 py-0.5 rounded-full text-[9px] uppercase font-bold <%= coup.is_active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <%= coup.is_active ? 'Ativo' : 'Inativo' %>
                  </span>
                </td>
                <td class="p-4 text-center">
                  <button type="button" 
                          onclick="toggleCouponStatus('<%= coup.id %>')"
                          class="px-3 py-1 bg-surface border border-border text-[10px] font-bold rounded-lg hover:bg-gray-100">
                    <%= coup.is_active ? 'Desativar' : 'Ativar' %>
                  </button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="8" class="p-12 text-center text-text-muted">Nenhum cupom cadastrado.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ADD COUPON MODAL -->
  <div id="coupon-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeCouponModal()"></div>
    <div class="flex items-end justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
      <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
      
      <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full border border-border">
        <!-- Header -->
        <div class="bg-primary text-white px-6 py-4 flex items-center justify-between">
          <h3 class="text-sm font-bold font-display uppercase tracking-wider">Novo Cupom</h3>
          <button type="button" class="text-white hover:text-accent focus:outline-none" onclick="closeCouponModal()">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <form id="coupon-form" class="p-6 space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          
          <div class="space-y-1">
            <label for="form-code" class="text-xs font-bold text-primary uppercase">Código do Cupom *</label>
            <input type="text" required id="form-code" name="code" placeholder="EX: BEMVINDO10" class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs font-bold uppercase tracking-wider focus:ring-1 focus:ring-primary focus:outline-none">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="form-type" class="text-xs font-bold text-primary uppercase">Tipo *</label>
              <select required id="form-type" name="type" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none cursor-pointer">
                <option value="percent">Porcentagem</option>
                <option value="fixed">Valor Fixo (R$)</option>
              </select>
            </div>
            <div class="space-y-1">
              <label for="form-value" class="text-xs font-bold text-primary uppercase">Valor de Desconto *</label>
              <input type="number" step="0.01" required id="form-value" name="value" placeholder="10.00" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="form-min" class="text-xs font-bold text-primary uppercase">Mínimo do Pedido (R$)</label>
              <input type="number" step="0.01" id="form-min" name="min_order_value" placeholder="0.00" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-uses" class="text-xs font-bold text-primary uppercase">Limite de Usos</label>
              <input type="number" id="form-uses" name="max_uses" placeholder="Sem limite" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
          </div>

          <div class="space-y-1">
            <label for="form-expiry" class="text-xs font-bold text-primary uppercase">Data de Vencimento</label>
            <input type="datetime-local" id="form-expiry" name="expires_at" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none cursor-pointer">
          </div>

          <!-- Alert feed -->
          <div id="form-alert" class="text-xs hidden font-bold mt-2"></div>

          <!-- Footer Actions -->
          <div class="pt-4 border-t border-border flex flex-row-reverse space-x-2 space-x-reverse">
            <button type="submit" class="px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors duration-200">
              Salvar Cupom
            </button>
            <button type="button" onclick="closeCouponModal()" class="px-5 py-2.5 bg-surface hover:bg-gray-100 text-primary border border-border text-xs font-bold rounded-xl transition-colors duration-200">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

</div>

<script>
  function openAddCouponModal() {
    document.getElementById('coupon-form').reset();
    document.getElementById('form-alert').className = 'text-xs hidden';
    document.getElementById('coupon-modal').classList.remove('hidden');
  }

  function closeCouponModal() {
    document.getElementById('coupon-modal').classList.add('hidden');
  }

  document.getElementById('coupon-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const alertDiv = document.getElementById('form-alert');
    alertDiv.innerHTML = 'Salvando...';
    alertDiv.className = 'text-xs text-text-muted block font-semibold';

    const data = {
      code: document.getElementById('form-code').value,
      type: document.getElementById('form-type').value,
      value: document.getElementById('form-value').value,
      min_order_value: document.getElementById('form-min').value || 0,
      max_uses: document.getElementById('form-uses').value || null,
      expires_at: document.getElementById('form-expiry').value || null,
      _csrf: document.querySelector('input[name="_csrf"]').value
    };

    fetch('/admin/cupons', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          alertDiv.innerHTML = data.error;
          alertDiv.className = 'text-xs text-danger block';
        } else if (data.errors) {
          alertDiv.innerHTML = data.errors.map(err => err.msg).join('<br>');
          alertDiv.className = 'text-xs text-danger block';
        } else {
          alertDiv.innerHTML = data.message;
          alertDiv.className = 'text-xs text-success font-bold block';
          setTimeout(() => {
            location.reload();
          }, 1000);
        }
      })
      .catch(() => {
        alertDiv.innerHTML = 'Erro ao se conectar ao servidor.';
        alertDiv.className = 'text-xs text-danger block';
      });
  });

  function toggleCouponStatus(id) {
    fetch(`/admin/cupons/${id}/toggle`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        _csrf: document.querySelector('input[name="_csrf"]').value
      })
    })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          alert(data.error);
        } else {
          alert(data.message);
          location.reload();
        }
      })
      .catch(() => {
        alert('Erro ao alterar status do cupom.');
      });
  }
</script>
