<div class="space-y-6 font-body">
  
  <!-- Header Action toolbar -->
  <div class="flex items-center justify-between">
    <p class="text-xs text-text-muted">Gerencie o acervo de cafés e produtos da Grão Nobre.</p>
    <button type="button" 
            onclick="openAddProductModal()"
            class="px-4 py-2 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors flex items-center space-x-1.5">
      <span>+ Novo Produto</span>
    </button>
  </div>

  <!-- Table list of products -->
  <div class="bg-white border border-border rounded-2xl overflow-hidden shadow-xs">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-xs">
        <thead>
          <tr class="bg-surface text-text-muted font-bold border-b border-border">
            <th class="p-4">SKU</th>
            <th class="p-4 w-[35%]">Produto</th>
            <th class="p-4">Categoria</th>
            <th class="p-4 text-right">Preço</th>
            <th class="p-4 text-center">Estoque</th>
            <th class="p-4 text-center">Status</th>
            <th class="p-4 text-center w-28">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (products && products.length > 0) { %>
            <% products.forEach(prod => { %>
              <tr class="<%= !prod.is_active ? 'bg-gray-50 opacity-60' : '' %>">
                <td class="p-4 font-mono text-[10px]"><%= prod.sku %></td>
                <td class="p-4">
                  <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-lg overflow-hidden border border-border bg-surface flex-shrink-0">
                      <% const img = (prod.images && prod.images.length > 0) ? prod.images[0] : '/uploads/placeholder.jpg'; %>
                      <img src="<%= typeof img === 'object' ? img.webp : img %>" class="w-full h-full object-cover" alt="<%= prod.name %>">
                    </div>
                    <div>
                      <h4 class="font-bold text-primary truncate max-w-[200px]"><%= prod.name %></h4>
                      <% if (prod.is_featured) { %>
                        <span class="text-[8px] font-bold text-accent tracking-wider uppercase">★ Destaque</span>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="p-4 text-text-muted"><%= prod.category ? prod.category.name : '---' %></td>
                <td class="p-4 text-right font-bold">R$ <%= parseFloat(prod.price).toFixed(2).replace('.', ',') %></td>
                <td class="p-4 text-center font-semibold"><%= prod.stock %></td>
                <td class="p-4 text-center">
                  <span class="px-2 py-0.5 rounded-full text-[9px] uppercase font-bold <%= prod.is_active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <%= prod.is_active ? 'Ativo' : 'Inativo' %>
                  </span>
                </td>
                <td class="p-4 text-center space-x-1">
                  <!-- Edit button with data attributes -->
                  <button type="button" 
                          onclick="openEditProductModal(this)"
                          data-id="<%= prod.id %>"
                          data-name="<%= prod.name %>"
                          data-description="<%= prod.description %>"
                          data-price="<%= prod.price %>"
                          data-compare_price="<%= prod.compare_price %>"
                          data-stock="<%= prod.stock %>"
                          data-sku="<%= prod.sku %>"
                          data-category_id="<%= prod.category_id %>"
                          data-weight_kg="<%= prod.weight_kg %>"
                          data-is_featured="<%= prod.is_featured %>"
                          data-is_active="<%= prod.is_active %>"
                          data-meta_title="<%= prod.meta_title %>"
                          data-meta_description="<%= prod.meta_description %>"
                          class="px-2 py-1 bg-surface border border-border text-[10px] font-bold rounded-lg hover:bg-gray-100 text-primary">
                    Editar
                  </button>
                  <button type="button" 
                          onclick="deleteProduct('<%= prod.id %>')"
                          class="px-2 py-1 bg-red-50 border border-red-200 text-[10px] font-bold rounded-lg hover:bg-red-100 text-danger">
                    Excluir
                  </button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="p-12 text-center text-text-muted">Nenhum produto cadastrado.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ADD / EDIT PRODUCT MODAL (Single modal toggled for both flows) -->
  <div id="product-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeProductModal()"></div>
    <div class="flex items-end justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
      <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
      
      <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full border border-border">
        <!-- Header -->
        <div class="bg-primary text-white px-6 py-4 flex items-center justify-between">
          <h3 class="text-sm font-bold font-display uppercase tracking-wider" id="modal-title-text">Adicionar Produto</h3>
          <button type="button" class="text-white hover:text-accent focus:outline-none" onclick="closeProductModal()">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <form id="product-form" class="p-6 space-y-4" enctype="multipart/form-data">
          <!-- Hidden input for ID (editing only) -->
          <input type="hidden" id="product_id" name="product_id">
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="form-name" class="text-xs font-bold text-primary">Nome do Produto *</label>
              <input type="text" required id="form-name" name="name" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-sku" class="text-xs font-bold text-primary">SKU *</label>
              <input type="text" required id="form-sku" name="sku" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-category" class="text-xs font-bold text-primary">Categoria *</label>
              <select required id="form-category" name="category_id" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none cursor-pointer">
                <option value="">Selecione...</option>
                <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>"><%= cat.name %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="space-y-1">
              <label for="form-weight" class="text-xs font-bold text-primary">Peso (kg) *</label>
              <input type="number" step="0.001" required id="form-weight" name="weight_kg" placeholder="0.250" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-price" class="text-xs font-bold text-primary">Preço (R$) *</label>
              <input type="number" step="0.01" required id="form-price" name="price" placeholder="49.90" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-compare-price" class="text-xs font-bold text-primary">Preço Comparativo/Riscado (R$)</label>
              <input type="number" step="0.01" id="form-compare-price" name="compare_price" placeholder="59.90" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-stock" class="text-xs font-bold text-primary">Estoque Inicial *</label>
              <input type="number" required id="form-stock" name="stock" placeholder="50" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-images" class="text-xs font-bold text-primary">Imagens (Múltiplas)</label>
              <input type="file" id="form-images" name="images" multiple accept="image/*" class="w-full bg-surface border border-border rounded-xl px-3 py-1.5 text-xs cursor-pointer focus:outline-none">
            </div>
            
            <div class="sm:col-span-2 space-y-1">
              <label for="form-desc" class="text-xs font-bold text-primary">Descrição *</label>
              <textarea required id="form-desc" name="description" rows="3" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none"></textarea>
            </div>

            <!-- Meta SEO Settings -->
            <div class="space-y-1">
              <label for="form-meta-title" class="text-xs font-bold text-primary">Meta Title (SEO)</label>
              <input type="text" id="form-meta-title" name="meta_title" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>
            <div class="space-y-1">
              <label for="form-meta-desc" class="text-xs font-bold text-primary">Meta Description (SEO)</label>
              <input type="text" id="form-meta-desc" name="meta_description" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
            </div>

            <div class="flex items-center space-x-6 sm:col-span-2 pt-2 border-t border-gray-100">
              <label class="flex items-center text-xs text-primary font-bold cursor-pointer">
                <input type="checkbox" id="form-featured" name="is_featured" value="true" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary mr-2 cursor-pointer">
                Produto em Destaque
              </label>
              <label class="flex items-center text-xs text-primary font-bold cursor-pointer">
                <input type="checkbox" id="form-active" name="is_active" value="true" checked class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary mr-2 cursor-pointer">
                Produto Ativo
              </label>
            </div>
          </div>

          <!-- Alert feed -->
          <div id="form-alert" class="text-xs hidden font-bold mt-2"></div>

          <!-- Footer Actions -->
          <div class="pt-4 border-t border-border flex flex-row-reverse space-x-2 space-x-reverse">
            <button type="submit" class="px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors duration-200">
              Salvar
            </button>
            <button type="button" onclick="closeProductModal()" class="px-5 py-2.5 bg-surface hover:bg-gray-100 text-primary border border-border text-xs font-bold rounded-xl transition-colors duration-200">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

</div>

<script>
  let editingId = null;

  function openAddProductModal() {
    editingId = null;
    document.getElementById('modal-title-text').innerText = 'Adicionar Produto';
    document.getElementById('product_id').value = '';
    document.getElementById('product-form').reset();
    document.getElementById('form-alert').className = 'text-xs hidden';
    
    // Toggle active state to checked by default on new items
    document.getElementById('form-active').checked = true;

    const el = document.getElementById('product-modal');
    el.classList.remove('hidden');
  }

  function openEditProductModal(btn) {
    document.getElementById('modal-title-text').innerText = 'Editar Produto';
    document.getElementById('product-form').reset();
    document.getElementById('form-alert').className = 'text-xs hidden';

    editingId = btn.getAttribute('data-id');
    document.getElementById('product_id').value = editingId;

    document.getElementById('form-name').value = btn.getAttribute('data-name');
    document.getElementById('form-desc').value = btn.getAttribute('data-description');
    document.getElementById('form-price').value = btn.getAttribute('data-price');
    
    const compVal = btn.getAttribute('data-compare_price');
    document.getElementById('form-compare-price').value = compVal !== 'null' ? compVal : '';
    
    document.getElementById('form-stock').value = btn.getAttribute('data-stock');
    document.getElementById('form-sku').value = btn.getAttribute('data-sku');
    document.getElementById('form-category').value = btn.getAttribute('data-category_id');
    document.getElementById('form-weight').value = btn.getAttribute('data-weight_kg');

    document.getElementById('form-meta-title').value = btn.getAttribute('data-meta_title') || '';
    document.getElementById('form-meta-desc').value = btn.getAttribute('data-meta_description') || '';

    document.getElementById('form-featured').checked = btn.getAttribute('data-is_featured') === 'true';
    document.getElementById('form-active').checked = btn.getAttribute('data-is_active') === 'true';

    const el = document.getElementById('product-modal');
    el.classList.remove('hidden');
  }

  function closeProductModal() {
    document.getElementById('product-modal').classList.add('hidden');
  }

  document.getElementById('product-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const alertDiv = document.getElementById('form-alert');
    alertDiv.innerHTML = 'Salvando...';
    alertDiv.className = 'text-xs text-text-muted block font-semibold';

    const formData = new FormData(this);

    // Make sure boolean states are parsed correctly
    formData.set('is_featured', document.getElementById('form-featured').checked ? 'true' : 'false');
    formData.set('is_active', document.getElementById('form-active').checked ? 'true' : 'false');

    const method = editingId ? 'PUT' : 'POST';
    const url = editingId ? `/admin/produtos/${editingId}` : '/admin/produtos';

    fetch(url, {
      method: method,
      body: formData
    })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          alertDiv.innerHTML = data.error;
          alertDiv.className = 'text-xs text-danger block';
        } else if (data.errors) {
          alertDiv.innerHTML = data.errors.map(err => err.msg).join('<br>');
          alertDiv.className = 'text-xs text-danger block';
        } else {
          alertDiv.innerHTML = data.message;
          alertDiv.className = 'text-xs text-success font-bold block';
          setTimeout(() => {
            location.reload();
          }, 1000);
        }
      })
      .catch(() => {
        alertDiv.innerHTML = 'Erro ao conectar ao servidor.';
        alertDiv.className = 'text-xs text-danger block';
      });
  });

  function deleteProduct(id) {
    if (confirm('Deseja realmente desativar (soft-delete) este produto? ele deixará de aparecer no catálogo.')) {
      fetch(`/admin/produtos/${id}`, {
        method: 'DELETE'
      })
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            alert(data.error);
          } else {
            alert(data.message);
            location.reload();
          }
        })
        .catch(() => {
          alert('Erro na requisição ao servidor.');
        });
    }
  }
</script>
