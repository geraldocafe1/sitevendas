<div class="space-y-6 font-body">

  <div class="flex items-center justify-between">
    <p class="text-xs text-text-muted">Gerencie os fornecedores parceiros para o modelo de dropshipping. Produtos vinculados a um fornecedor ativo notificam automaticamente o fornecedor por email quando um pedido for realizado.</p>
    <button type="button"
            onclick="openAddSupplierModal()"
            class="px-4 py-2 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors flex items-center space-x-1.5">
      <span>+ Novo Fornecedor</span>
    </button>
  </div>

  <!-- Dropshipping Info Banner -->
  <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 flex items-start space-x-3">
    <span class="text-xl mt-0.5">🚚</span>
    <div>
      <p class="text-xs font-bold text-amber-800">Como funciona o Dropshipping nesta loja?</p>
      <p class="text-xs text-amber-700 mt-1">Quando um cliente faz um pedido com produtos vinculados a um fornecedor ativo, um <strong>email automático</strong> é enviado ao fornecedor com o endereço do cliente e os produtos. O fornecedor embala e envia diretamente. Você fica com a margem (preço de venda - custo do fornecedor).</p>
    </div>
  </div>

  <!-- Suppliers Table -->
  <div class="bg-white border border-border rounded-2xl overflow-hidden shadow-xs">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-xs">
        <thead>
          <tr class="bg-surface text-text-muted font-bold border-b border-border">
            <th class="p-4">Fornecedor</th>
            <th class="p-4">Contato</th>
            <th class="p-4">Email</th>
            <th class="p-4">WhatsApp</th>
            <th class="p-4 text-center">Produtos</th>
            <th class="p-4 text-center">Status</th>
            <th class="p-4 text-center w-36">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (suppliers && suppliers.length > 0) { %>
            <% suppliers.forEach(sup => { %>
              <tr class="<%= !sup.is_active ? 'bg-gray-50 opacity-60' : 'hover:bg-surface/50' %> transition-colors" id="supplier-row-<%= sup.id %>">
                <td class="p-4">
                  <div class="font-bold text-primary"><%= sup.name %></div>
                  <% if (sup.notes) { %>
                    <div class="text-text-muted text-[10px] mt-0.5 max-w-xs truncate"><%= sup.notes %></div>
                  <% } %>
                </td>
                <td class="p-4 text-text-muted"><%= sup.contact_name || '---' %></td>
                <td class="p-4">
                  <a href="mailto:<%= sup.email %>" class="text-blue-600 hover:underline"><%= sup.email %></a>
                </td>
                <td class="p-4 text-text-muted"><%= sup.whatsapp || '---' %></td>
                <td class="p-4 text-center">
                  <span class="px-2 py-1 bg-primary/10 text-primary rounded-lg font-bold"><%= sup.productCount %></span>
                </td>
                <td class="p-4 text-center">
                  <span class="px-2 py-0.5 rounded-full text-[9px] uppercase font-bold <%= sup.is_active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <%= sup.is_active ? 'Ativo' : 'Inativo' %>
                  </span>
                </td>
                <td class="p-4 text-center">
                  <div class="flex items-center justify-center space-x-2">
                    <button type="button"
                            onclick="openEditSupplierModal('<%= sup.id %>', '<%= sup.name.replace(/'/g, "\\'") %>', '<%= sup.email %>', '<%= (sup.whatsapp||'').replace(/'/g, "\\'") %>', '<%= (sup.contact_name||'').replace(/'/g, "\\'") %>', '<%= (sup.notes||'').replace(/'/g, "\\'") %>', <%= sup.is_active %>)"
                            class="px-3 py-1 bg-surface border border-border text-[10px] font-bold rounded-lg hover:bg-gray-100">
                      Editar
                    </button>
                    <% if (sup.is_active) { %>
                      <button type="button"
                              onclick="deleteSupplier('<%= sup.id %>')"
                              class="px-3 py-1 bg-red-50 border border-red-200 text-red-600 text-[10px] font-bold rounded-lg hover:bg-red-100">
                        Desativar
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="p-12 text-center text-text-muted">
                <div class="text-3xl mb-2">🏭</div>
                <div class="font-semibold">Nenhum fornecedor cadastrado ainda.</div>
                <div class="text-[11px] mt-1">Cadastre seu primeiro fornecedor e vincule produtos a ele.</div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ADD / EDIT SUPPLIER MODAL -->
<div id="supplier-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeSupplierModal()"></div>
  <div class="flex items-end justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
    <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

    <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-border">
      <!-- Header -->
      <div class="bg-primary text-white px-6 py-4 flex items-center justify-between">
        <h3 id="modal-title-text" class="text-sm font-bold font-display uppercase tracking-wider">Novo Fornecedor</h3>
        <button type="button" class="text-white hover:text-accent focus:outline-none" onclick="closeSupplierModal()">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="supplier-form" class="p-6 space-y-4">
        <input type="hidden" id="supplier-id" value="">

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1 col-span-2">
            <label for="sup-name" class="text-xs font-bold text-primary uppercase">Nome da Empresa *</label>
            <input type="text" required id="sup-name" name="name" placeholder="Ex: Fazenda Bela Vista" class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
          </div>

          <div class="space-y-1">
            <label for="sup-email" class="text-xs font-bold text-primary uppercase">Email para Pedidos *</label>
            <input type="email" required id="sup-email" name="email" placeholder="pedidos@fornecedor.com" class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
          </div>

          <div class="space-y-1">
            <label for="sup-whatsapp" class="text-xs font-bold text-primary uppercase">WhatsApp</label>
            <input type="text" id="sup-whatsapp" name="whatsapp" placeholder="5511999999999" class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
          </div>

          <div class="space-y-1 col-span-2">
            <label for="sup-contact" class="text-xs font-bold text-primary uppercase">Nome do Responsável</label>
            <input type="text" id="sup-contact" name="contact_name" placeholder="Ex: João Silva" class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs focus:ring-1 focus:ring-primary focus:outline-none">
          </div>

          <div class="space-y-1 col-span-2">
            <label for="sup-notes" class="text-xs font-bold text-primary uppercase">Observações</label>
            <textarea id="sup-notes" name="notes" rows="2" placeholder="Prazo de envio, produtos disponíveis, etc." class="w-full bg-surface border border-border rounded-xl px-3 py-2.5 text-xs focus:ring-1 focus:ring-primary focus:outline-none resize-none"></textarea>
          </div>

          <!-- Edit only: active status -->
          <div class="space-y-1 col-span-2 hidden" id="status-field">
            <label class="text-xs font-bold text-primary uppercase">Status</label>
            <select id="sup-status" name="is_active" class="w-full bg-surface border border-border rounded-xl px-3 py-2 text-xs focus:ring-1 focus:ring-primary focus:outline-none cursor-pointer">
              <option value="true">Ativo</option>
              <option value="false">Inativo</option>
            </select>
          </div>
        </div>

        <!-- Alert feed -->
        <div id="sup-alert" class="text-xs hidden font-bold mt-2"></div>

        <!-- Footer Actions -->
        <div class="pt-4 border-t border-border flex flex-row-reverse space-x-2 space-x-reverse">
          <button type="submit" class="px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-md transition-colors duration-200">
            Salvar Fornecedor
          </button>
          <button type="button" onclick="closeSupplierModal()" class="px-5 py-2.5 bg-surface hover:bg-gray-100 text-primary border border-border text-xs font-bold rounded-xl transition-colors duration-200">
            Cancelar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  let editingId = null;

  function openAddSupplierModal() {
    editingId = null;
    document.getElementById('supplier-form').reset();
    document.getElementById('supplier-id').value = '';
    document.getElementById('modal-title-text').textContent = 'Novo Fornecedor';
    document.getElementById('status-field').classList.add('hidden');
    document.getElementById('sup-alert').className = 'text-xs hidden';
    document.getElementById('supplier-modal').classList.remove('hidden');
  }

  function openEditSupplierModal(id, name, email, whatsapp, contact, notes, isActive) {
    editingId = id;
    document.getElementById('supplier-id').value = id;
    document.getElementById('sup-name').value = name;
    document.getElementById('sup-email').value = email;
    document.getElementById('sup-whatsapp').value = whatsapp;
    document.getElementById('sup-contact').value = contact;
    document.getElementById('sup-notes').value = notes;
    document.getElementById('sup-status').value = isActive ? 'true' : 'false';
    document.getElementById('modal-title-text').textContent = 'Editar Fornecedor';
    document.getElementById('status-field').classList.remove('hidden');
    document.getElementById('sup-alert').className = 'text-xs hidden';
    document.getElementById('supplier-modal').classList.remove('hidden');
  }

  function closeSupplierModal() {
    document.getElementById('supplier-modal').classList.add('hidden');
    editingId = null;
  }

  document.getElementById('supplier-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const alertDiv = document.getElementById('sup-alert');
    alertDiv.innerHTML = 'Salvando...';
    alertDiv.className = 'text-xs text-text-muted block font-semibold';

    const data = {
      name: document.getElementById('sup-name').value,
      email: document.getElementById('sup-email').value,
      whatsapp: document.getElementById('sup-whatsapp').value,
      contact_name: document.getElementById('sup-contact').value,
      notes: document.getElementById('sup-notes').value,
      is_active: document.getElementById('sup-status').value
    };

    const url = editingId ? `/admin/fornecedores/${editingId}` : '/admin/fornecedores';
    const method = editingId ? 'PUT' : 'POST';

    fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          alertDiv.innerHTML = data.error;
          alertDiv.className = 'text-xs text-red-600 block';
        } else {
          alertDiv.innerHTML = data.message;
          alertDiv.className = 'text-xs text-green-600 font-bold block';
          setTimeout(() => location.reload(), 900);
        }
      })
      .catch(() => {
        alertDiv.innerHTML = 'Erro ao conectar ao servidor.';
        alertDiv.className = 'text-xs text-red-600 block';
      });
  });

  function deleteSupplier(id) {
    if (!confirm('Desativar este fornecedor? Produtos vinculados a ele deixarão de notificar automaticamente.')) return;
    fetch(`/admin/fornecedores/${id}`, {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' }
    })
      .then(res => res.json())
      .then(data => {
        if (data.error) { alert(data.error); }
        else { location.reload(); }
      })
      .catch(() => alert('Erro ao desativar fornecedor.'));
  }
</script>
