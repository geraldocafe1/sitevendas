<% if (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length > 0) { %>
  <nav class="flex py-3 text-text-muted text-xs sm:text-sm font-body" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-2">
      <li class="inline-flex items-center">
        <a href="/" class="inline-flex items-center hover:text-primary transition-colors duration-200">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
          </svg>
          Home
        </a>
      </li>
      <% breadcrumbs.forEach((crumb, index) => { %>
        <li>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <% if (index === breadcrumbs.length - 1) { %>
              <span class="ml-1 text-primary font-medium md:ml-2 truncate" aria-current="page"><%= crumb.name %></span>
            <% } else { %>
              <a href="<%= crumb.url %>" class="ml-1 hover:text-primary transition-colors duration-200 md:ml-2"><%= crumb.name %></a>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ol>
  </nav>

  <!-- Schema.org JSON-LD Breadcrumbs -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "<%= storeUrl %>/"
      },
      <% breadcrumbs.forEach((crumb, idx) => { %>
        {
          "@type": "ListItem",
          "position": <%= idx + 2 %>,
          "name": "<%= crumb.name.replace(/"/g, '\\"') %>",
          "item": "<%= storeUrl %><%= crumb.url %>"
        }<%= idx < breadcrumbs.length - 1 ? ',' : '' %>
      <% }) %>
    ]
  }
  </script>
<% } %>
