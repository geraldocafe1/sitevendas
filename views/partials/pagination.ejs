<% if (totalPages > 1) { %>
  <nav class="flex justify-center items-center space-x-1 my-8" aria-label="Navegação de páginas">
    <!-- Previous Button -->
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + searchQuery : '' %><%= activeCategorySlug ? '&category=' + activeCategorySlug : '' %><%= minPrice ? '&min=' + minPrice : '' %><%= maxPrice ? '&max=' + maxPrice : '' %><%= sortOption ? '&sort=' + sortOption : '' %>" 
         class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-white text-text hover:bg-surface hover:text-primary transition-colors duration-200" 
         aria-label="Anterior">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    <% } else { %>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-gray-50 text-gray-400 cursor-not-allowed">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </span>
    <% } %>

    <!-- Page Numbers -->
    <% for (let i = 1; i <= totalPages; i++) { %>
      <% if (i === currentPage) { %>
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary text-white font-bold" aria-current="page">
          <%= i %>
        </span>
      <% } else { %>
        <a href="?page=<%= i %><%= searchQuery ? '&q=' + searchQuery : '' %><%= activeCategorySlug ? '&category=' + activeCategorySlug : '' %><%= minPrice ? '&min=' + minPrice : '' %><%= maxPrice ? '&max=' + maxPrice : '' %><%= sortOption ? '&sort=' + sortOption : '' %>" 
           class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-white text-text hover:bg-surface hover:text-primary transition-colors duration-200">
          <%= i %>
        </a>
      <% } %>
    <% } %>

    <!-- Next Button -->
    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + searchQuery : '' %><%= activeCategorySlug ? '&category=' + activeCategorySlug : '' %><%= minPrice ? '&min=' + minPrice : '' %><%= maxPrice ? '&max=' + maxPrice : '' %><%= sortOption ? '&sort=' + sortOption : '' %>" 
         class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-white text-text hover:bg-surface hover:text-primary transition-colors duration-200" 
         aria-label="Próximo">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    <% } else { %>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-gray-50 text-gray-400 cursor-not-allowed">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    <% } %>
  </nav>
<% } %>
