  <!-- RECENT SALES TOAST NOTIFICATION -->
  <div id="recent-sale-toast" class="fixed bottom-6 left-6 z-40 bg-white border border-border rounded-xl shadow-2xl p-4 flex items-center space-x-3 max-w-xs transform translate-y-24 opacity-0 transition-all duration-500 hidden font-body">
    <div class="w-10 h-10 rounded-lg bg-surface flex-shrink-0 overflow-hidden">
      <img id="toast-product-image" src="/uploads/placeholder.jpg" class="w-full h-full object-cover" alt="Produto comprado">
    </div>
    <div class="flex-1">
      <p class="text-[10px] text-text-muted font-bold uppercase tracking-wider">Venda recente</p>
      <p class="text-xs text-text font-bold leading-tight" id="toast-message">João de São Paulo comprou um produto!</p>
      <p class="text-[9px] text-success font-semibold mt-0.5">há 3 minutos</p>
    </div>
  </div>
</footer>

<script>
  (function() {
    // Recent Sales Toast configuration
    const names = ['João', 'Maria', 'Pedro', 'Ana', 'Lucas', 'Carlos', 'Mariana', 'Beatriz', 'Juliana', 'Felipe', 'Mateus', 'Gabriel', 'Laura', 'Luiza', 'Camila', 'Gustavo', 'Rafael', 'Diego', 'Rodrigo', 'Thiago'];
    const cities = ['São Paulo - SP', 'Rio de Janeiro - RJ', 'Belo Horizonte - MG', 'Curitiba - PR', 'Porto Alegre - RS', 'Campinas - SP', 'Santos - SP', 'Niterói - RJ', 'Vitória - ES', 'Florianópolis - SC', 'Salvador - BA', 'Recife - PE', 'Fortaleza - CE', 'Brasília - DF', 'Goiânia - GO', 'Uberlândia - MG', 'Joinville - SC', 'Ribeirão Preto - SP', 'Sorocaba - SP', 'São José dos Campos - SP'];
    
    // We fetch a list of products to simulate recent sales
    let productsList = [];

    // Fetch products on load
    fetch('/api/products?limit=8')
      .then(res => res.json())
      .then(data => {
        if (data.products && data.products.length > 0) {
          productsList = data.products;
          // Start the notification loop
          scheduleNextToast();
        }
      })
      .catch(err => console.log('Error fetching toast products:', err));

    function scheduleNextToast() {
      // Random interval between 90s and 180s (90000ms - 180000ms)
      const interval = Math.floor(Math.random() * (180000 - 90000 + 1)) + 90000;
      setTimeout(showToast, interval);
    }

    function showToast() {
      if (productsList.length === 0) return;

      const toast = document.getElementById('recent-sale-toast');
      const img = document.getElementById('toast-product-image');
      const msg = document.getElementById('toast-message');

      if (!toast || !img || !msg) return;

      // Select random item
      const product = productsList[Math.floor(Math.random() * productsList.length)];
      const name = names[Math.floor(Math.random() * names.length)];
      const city = cities[Math.floor(Math.random() * cities.length)];

      const isWebpObj = typeof product.images[0] === 'object';
      img.src = isWebpObj ? product.images[0].webp : product.images[0];
      img.alt = product.name;

      msg.innerHTML = `<strong>${name}</strong> de <strong>${city}</strong> comprou <strong>${product.name}</strong>`;

      // Show toast
      toast.classList.remove('hidden');
      setTimeout(() => {
        toast.classList.remove('translate-y-24', 'opacity-0');
      }, 50);

      // Hide after 8 seconds
      setTimeout(() => {
        toast.classList.add('translate-y-24', 'opacity-0');
        setTimeout(() => {
          toast.classList.add('hidden');
          scheduleNextToast(); // Schedule next
        }, 500);
      }, 8000);
    }
  })();
</script>
