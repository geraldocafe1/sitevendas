<header class="sticky top-0 z-40 bg-white border-b border-border shadow-xs font-body">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      
      <!-- Brand Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <svg class="w-8 h-8 text-accent fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H9v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          <span class="text-lg sm:text-xl font-extrabold text-primary font-display tracking-tight"><%= storeName %></span>
        </a>
      </div>

      <!-- Center Search Bar (with Debounce, hidden on small mobile) -->
      <div class="hidden md:block flex-1 max-w-md mx-8 relative">
        <form action="/produtos" method="GET" id="search-form">
          <div class="relative">
            <input type="text" 
                   name="q" 
                   id="search-input" 
                   placeholder="Buscar café especial, moído ou kit..." 
                   class="w-full bg-surface border border-border rounded-xl pl-10 pr-4 py-2.5 text-xs text-text focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all duration-200"
                   autocomplete="off">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-muted">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>
        </form>
        <!-- Instant search results dropdown -->
        <div id="search-results-dropdown" class="absolute top-full left-0 right-0 mt-2 bg-white border border-border rounded-xl shadow-lg z-50 p-2 hidden overflow-hidden">
          <div id="search-results-list" class="divide-y divide-gray-100 max-h-80 overflow-y-auto pr-1"></div>
        </div>
      </div>

      <!-- Navigation Links & Action Badges -->
      <div class="flex items-center space-x-2 sm:space-x-4">
        
        <!-- Web links (hidden on mobile) -->
        <nav class="hidden lg:flex items-center space-x-6 text-sm font-semibold text-text mr-4">
          <a href="/produtos" class="hover:text-primary-light transition-colors">Cafés</a>
          <a href="/blog" class="hover:text-primary-light transition-colors">Blog</a>
          <a href="/termos" class="hover:text-primary-light transition-colors">Termos</a>
        </nav>

        <!-- Wishlist Button -->
        <a href="/favoritos" class="relative p-2 text-text hover:text-primary-light transition-colors" aria-label="Favoritos">
          <svg class="w-6 h-6 stroke-current fill-none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span id="wishlist-badge" class="absolute top-0 right-0 inline-flex items-center justify-center px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-accent text-primary leading-none hidden">0</span>
        </a>

        <!-- Cart Drawer Trigger -->
        <button type="button" id="cart-drawer-trigger" class="relative p-2 text-text hover:text-primary-light transition-colors focus:outline-none" aria-label="Carrinho">
          <svg class="w-6 h-6 stroke-current fill-none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          <span id="cart-badge" class="absolute top-0 right-0 inline-flex items-center justify-center px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-primary text-white leading-none hidden">0</span>
        </button>

        <!-- Auth profile drop-down or login button -->
        <div class="relative" id="profile-dropdown-container">
          <% if (typeof user !== 'undefined' && user) { %>
            <button type="button" id="btn-profile-toggle" class="flex items-center space-x-1.5 p-1 rounded-xl hover:bg-surface transition-colors focus:outline-none">
              <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center text-xs uppercase shadow-sm">
                <%= user.name.slice(0, 2) %>
              </div>
              <span class="hidden md:inline text-xs font-semibold text-text"><%= user.name.split(' ')[0] %></span>
              <svg class="w-4 h-4 text-text-muted hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown Menu -->
            <div id="profile-dropdown-menu" class="absolute right-0 mt-2 w-48 bg-white border border-border rounded-xl shadow-lg z-50 hidden overflow-hidden">
              <div class="px-4 py-2.5 border-b border-gray-100 bg-surface">
                <p class="text-[10px] text-text-muted uppercase font-bold tracking-wider">Logado como</p>
                <p class="text-xs font-bold text-primary truncate"><%= user.email %></p>
              </div>
              <div class="py-1">
                <% if (user.role === 'admin') { %>
                  <a href="/admin" class="flex items-center px-4 py-2 text-xs text-text hover:bg-surface font-semibold">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    Painel Admin
                  </a>
                <% } %>
                <a href="/logout" class="flex items-center px-4 py-2 text-xs text-danger hover:bg-surface font-semibold border-t border-gray-100">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                  Sair da Conta
                </a>
              </div>
            </div>
          <% } else { %>
            <a href="/login" class="inline-flex items-center justify-center px-4 py-2 border border-border bg-white text-xs font-bold rounded-xl text-primary hover:bg-surface transition-colors shadow-xs">
              Entrar
            </a>
          <% } %>
        </div>

        <!-- Mobile Menu Trigger -->
        <button type="button" id="mobile-menu-trigger" class="lg:hidden p-2 text-text hover:text-primary-light focus:outline-none" aria-label="Abrir Menu">
          <svg class="w-6 h-6 fill-none stroke-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu" class="lg:hidden border-t border-border bg-white hidden">
    <div class="px-4 pt-3 pb-4 space-y-2">
      <!-- Search input for mobile inside menu -->
      <form action="/produtos" method="GET" class="mb-4">
        <input type="text" name="q" placeholder="Buscar café..." class="w-full bg-surface border border-border rounded-xl px-4 py-2 text-xs">
      </form>
      <a href="/produtos" class="block px-3 py-2 rounded-lg text-sm font-semibold hover:bg-surface">Cafés</a>
      <a href="/blog" class="block px-3 py-2 rounded-lg text-sm font-semibold hover:bg-surface">Blog</a>
      <a href="/favoritos" class="block px-3 py-2 rounded-lg text-sm font-semibold hover:bg-surface">Favoritos</a>
      <a href="/termos" class="block px-3 py-2 rounded-lg text-sm font-semibold hover:bg-surface">Termos</a>
    </div>
  </div>
</header>

<!-- CART SLIDE-IN DRAWER (Desktop / Tablet) -->
<div id="cart-drawer" class="fixed inset-0 z-50 hidden transition-opacity duration-300 ease-in-out font-body" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div id="cart-drawer-backdrop" class="fixed inset-0 bg-gray-500 bg-opacity-75 opacity-0 transition-opacity duration-300"></div>

  <!-- Drawer Body -->
  <div class="fixed inset-y-0 right-0 max-w-full flex pl-10">
    <div id="cart-drawer-content" class="w-screen max-w-md bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300 ease-in-out border-l border-border">
      <!-- Header -->
      <div class="px-6 py-5 bg-primary text-white flex items-center justify-between">
        <h2 class="text-md font-bold font-display flex items-center space-x-2">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span>Seu Carrinho</span>
        </h2>
        <button type="button" id="cart-drawer-close" class="text-white hover:text-accent focus:outline-none">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Items List -->
      <div class="flex-1 overflow-y-auto px-6 py-4 divide-y divide-gray-100" id="cart-drawer-items">
        <!-- Dyn. Populated by cart.js -->
        <div class="flex flex-col items-center justify-center h-full text-center text-text-muted space-y-3 py-10">
          <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <p class="text-xs font-semibold">Seu carrinho está vazio.</p>
          <a href="/produtos" class="px-4 py-2 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-lg shadow-sm">Ver Catálogo</a>
        </div>
      </div>

      <!-- Summary & Footer -->
      <div class="border-t border-border px-6 py-5 bg-surface space-y-4">
        <div class="flex items-center justify-between text-sm font-bold text-primary">
          <span>Subtotal:</span>
          <span id="cart-drawer-subtotal">R$ 0,00</span>
        </div>
        <p class="text-[10px] text-text-muted leading-relaxed">
          Frete grátis para compras acima de R$ 150,00! Impostos inclusos no checkout.
        </p>
        <div class="flex flex-col space-y-2">
          <a href="/checkout" class="w-full py-3 bg-primary hover:bg-primary-light text-white text-center text-xs font-bold rounded-xl shadow-md transition-colors">
            Finalizar Compra
          </a>
          <a href="/carrinho" class="w-full py-3 bg-white hover:bg-surface text-primary border border-border text-center text-xs font-bold rounded-xl transition-colors">
            Ver Carrinho Completo
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
