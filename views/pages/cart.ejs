<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-body">
  <!-- Breadcrumb -->
  <%- include('../partials/breadcrumb', { 
    breadcrumbs: [
      { name: 'Carrinho', url: '/carrinho' }
    ] 
  }) %>

  <h1 class="text-2xl sm:text-3xl font-extrabold text-primary font-display mb-8 mt-4">Seu Carrinho</h1>

  <!-- Cart layouts -->
  <div class="flex flex-col lg:flex-row gap-8" id="cart-main-container">
    <!-- LEFT: Cart Items (Desktop Table / Mobile Rows) -->
    <div class="flex-grow bg-white border border-border rounded-2xl p-6 h-fit space-y-6">
      
      <!-- Table for Desktop -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-border text-xs text-text-muted uppercase font-bold">
              <th class="pb-3 w-[45%]">Produto</th>
              <th class="pb-3 text-center">Quantidade</th>
              <th class="pb-3 text-right">Unitário</th>
              <th class="pb-3 text-right">Total</th>
              <th class="pb-3 text-center w-12">Remover</th>
            </tr>
          </thead>
          <tbody id="cart-desktop-tbody" class="divide-y divide-gray-100">
            <!-- Populated dynamically by js/cart.js -->
            <tr>
              <td colspan="5" class="py-12 text-center text-text-muted text-xs">Carregando itens...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile List -->
      <div id="cart-mobile-list" class="md:hidden divide-y divide-gray-100 space-y-4">
        <!-- Populated dynamically by js/cart.js -->
        <p class="py-12 text-center text-text-muted text-xs">Carregando itens...</p>
      </div>

    </div>

    <!-- RIGHT: Summary Box -->
    <div class="w-full lg:w-96 flex-shrink-0 bg-white border border-border rounded-2xl p-6 h-fit space-y-6">
      <h3 class="text-md font-bold text-primary font-display pb-3 border-b border-border">Resumo da Compra</h3>
      
      <div class="space-y-3 text-xs">
        <div class="flex justify-between items-center text-text-muted">
          <span>Subtotal:</span>
          <strong class="text-primary text-sm" id="cart-summary-subtotal">R$ 0,00</strong>
        </div>

        <!-- Coupon check field -->
        <div class="border-y border-gray-100 py-4 space-y-3">
          <div class="flex space-x-2">
            <input type="text" 
                   id="cart-coupon-input" 
                   placeholder="CUPOM DE DESCONTO" 
                   class="bg-surface border border-border rounded-xl px-3 py-2 text-xs flex-grow uppercase font-semibold focus:outline-none">
            <button type="button" 
                    id="btn-apply-coupon" 
                    class="px-4 py-2 bg-white border border-border text-xs font-bold rounded-xl text-primary hover:bg-surface transition-colors focus:outline-none">
              Aplicar
            </button>
          </div>
          <div id="coupon-feedback" class="text-[10px] hidden font-bold"></div>
        </div>

        <div class="flex justify-between items-center text-danger hidden" id="cart-summary-discount-row">
          <span>Desconto (<span id="cart-summary-coupon-code">---</span>):</span>
          <strong class="text-danger text-sm" id="cart-summary-discount">- R$ 0,00</strong>
        </div>

        <div class="flex justify-between items-center text-text-muted">
          <span>Frete estimado:</span>
          <strong class="text-primary text-sm" id="cart-summary-shipping">R$ 0,00</strong>
        </div>

        <div class="flex justify-between items-center text-base font-extrabold text-primary border-t border-border pt-4">
          <span>Total:</span>
          <span class="text-lg font-black text-accent" id="cart-summary-total">R$ 0,00</span>
        </div>
      </div>

      <div class="flex flex-col space-y-2 pt-2">
        <a href="/checkout" class="w-full py-3.5 bg-primary hover:bg-primary-light text-white text-center text-xs font-bold rounded-xl shadow-lg transition-colors">
          Ir para o Checkout
        </a>
        <a href="/produtos" class="w-full py-3 text-white bg-transparent border border-border hover:bg-surface text-center text-xs font-bold rounded-xl text-primary transition-all">
          Continuar Comprando
        </a>
      </div>
    </div>
  </div>

  <!-- EMPTY STATE CONTAINER (Hidden by default) -->
  <div class="bg-white border border-border rounded-2xl p-16 text-center flex flex-col items-center justify-center space-y-4 hidden" id="cart-empty-state">
    <div class="w-20 h-20 rounded-full bg-surface flex items-center justify-center text-3xl text-accent">🛒</div>
    <h3 class="text-lg font-bold text-primary font-display">Seu carrinho está vazio</h3>
    <p class="text-xs text-text-muted max-w-sm leading-relaxed">
      Você ainda não adicionou nenhum café especial ou acessório no seu carrinho. Explore nosso catálogo para encontrar o grão ideal!
    </p>
    <a href="/produtos" class="px-8 py-3 bg-primary hover:bg-primary-light text-white text-xs font-bold rounded-xl shadow-lg transition-colors duration-200">
      Ver Catálogo de Cafés
    </a>
  </div>
</div>
