<!-- HERO BANNER -->
<section class="relative bg-primary overflow-hidden py-20 lg:py-32 font-body">
  <div class="absolute inset-0 bg-radial-gradient opacity-30 pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col lg:flex-row items-center gap-12">
    <!-- Hero Text -->
    <div class="w-full lg:w-1/2 text-left space-y-6">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-accent bg-opacity-10 text-accent uppercase tracking-wider">
        Sabor de Origem Nobre
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold font-display text-white leading-tight tracking-tight">
        O melhor café especial colhido e torrado para você
      </h1>
      <p class="text-sm sm:text-base text-gray-300 max-w-lg leading-relaxed">
        Descubra notas sensoriais inigualáveis de grãos 100% arábica cultivados de forma sustentável pelas famílias produtoras mais tradicionais do Brasil.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a href="/produtos" class="px-8 py-3.5 bg-accent hover:bg-yellow-600 text-primary font-bold text-xs rounded-xl shadow-lg transition-colors duration-200">
          Comprar Cafés
        </a>
        <a href="/blog" class="px-8 py-3.5 bg-transparent hover:bg-white hover:bg-opacity-5 text-white border border-gray-600 hover:border-white font-bold text-xs rounded-xl transition-all duration-200">
          Nosso Blog
        </a>
      </div>
    </div>

    <!-- Hero Image Stack (Premium look) -->
    <div class="w-full lg:w-1/2 flex justify-center relative">
      <div class="relative w-80 sm:w-96 aspect-square rounded-3xl overflow-hidden shadow-2xl border border-gray-800">
        <img src="/images/hero_coffee.png" alt="Preparo de café especial" class="w-full h-full object-cover">
      </div>
    </div>
  </div>
</section>

<!-- CATEGORIES SECTOR -->
<section class="py-16 bg-white font-body">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-xl mx-auto mb-12">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-primary font-display">Navegue por Categorias</h2>
      <p class="text-xs sm:text-sm text-text-muted mt-2">Escolha o formato ideal para saborear o seu Grão Nobre.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
      <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
        <% categories.forEach(cat => { %>
          <a href="/produtos?category=<%= cat.slug %>" class="group flex flex-col items-center text-center p-4 rounded-2xl border border-border hover:border-accent hover:shadow-md transition-all duration-300">
            <div class="w-20 h-20 rounded-full overflow-hidden bg-surface mb-4 border border-gray-100 group-hover:scale-110 transition-transform">
              <img src="<%= cat.image_url || '/uploads/placeholder.jpg' %>" alt="<%= cat.name %>" class="w-full h-full object-cover">
            </div>
            <h3 class="text-xs sm:text-sm font-bold text-primary group-hover:text-primary-light transition-colors"><%= cat.name %></h3>
          </a>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-text-muted col-span-full text-center">Nenhuma categoria cadastrada.</p>
      <% } %>
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="py-16 bg-surface font-body">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-12 gap-4">
      <div>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-primary font-display">Nossos Destaques</h2>
        <p class="text-xs text-text-muted mt-2">Os grãos e microlotes mais desejados pelos amantes do café.</p>
      </div>
      <a href="/produtos" class="text-xs font-bold text-primary hover:text-primary-light flex items-center space-x-1.5 border-b border-primary hover:border-primary-light pb-0.5">
        <span>Ver catálogo completo</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
        <% featuredProducts.forEach(prod => { %>
          <div>
            <%- include('../partials/product-card', { product: prod }) %>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-text-muted col-span-full text-center">Nenhum produto em destaque.</p>
      <% } %>
    </div>
  </div>
</section>

<!-- URGENCY PROMO TIMER BANNER (CRO) -->
<section class="py-12 bg-primary text-white font-body relative overflow-hidden border-y border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col lg:flex-row items-center justify-between gap-8">
    <div class="space-y-3 text-center lg:text-left">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-danger text-white uppercase tracking-wider">
        Oferta Relâmpago
      </span>
      <h2 class="text-xl sm:text-2xl lg:text-3xl font-extrabold font-display">10% de Desconto em todo o site!</h2>
      <p class="text-xs text-gray-400 max-w-md">Aplique o cupom <strong class="text-accent text-sm">BEMVINDO10</strong> na finalização da compra. Aproveite!</p>
    </div>

    <!-- Countdown Timer -->
    <div class="flex flex-col items-center space-y-2">
      <p class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">A oferta termina em:</p>
      <!-- timer component using data-countdown attribute -->
      <div class="flex items-center space-x-2 text-primary font-bold font-display" data-countdown="24h">
        <div class="flex flex-col items-center bg-white px-3 py-2 rounded-xl min-w-14">
          <span id="countdown-hours" class="text-lg">00</span>
          <span class="text-[8px] text-text-muted uppercase font-bold">Horas</span>
        </div>
        <span class="text-white text-lg font-bold">:</span>
        <div class="flex flex-col items-center bg-white px-3 py-2 rounded-xl min-w-14">
          <span id="countdown-minutes" class="text-lg">00</span>
          <span class="text-[8px] text-text-muted uppercase font-bold">Minutos</span>
        </div>
        <span class="text-white text-lg font-bold">:</span>
        <div class="flex flex-col items-center bg-white px-3 py-2 rounded-xl min-w-14">
          <span id="countdown-seconds" class="text-lg">00</span>
          <span class="text-[8px] text-text-muted uppercase font-bold">Segundos</span>
        </div>
      </div>
    </div>
  </div>
</section>

