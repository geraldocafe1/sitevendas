<!-- RECENT BLOG ARTICLES -->
<section class="py-16 bg-surface font-body border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-xl mx-auto mb-12">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-primary font-display">Aprenda com Especialistas</h2>
      <p class="text-xs sm:text-sm text-text-muted mt-2">Dicas de extração, curiosidades, receitas e segredos dos baristas.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% if (typeof latestPosts !== 'undefined' && latestPosts.length > 0) { %>
        <% latestPosts.forEach(post => { %>
          <article class="bg-white rounded-2xl border border-border overflow-hidden hover:shadow-md transition-shadow flex flex-col h-full">
            <a href="/blog/<%= post.slug %>" class="block aspect-video w-full overflow-hidden">
              <img src="<%= post.cover_image || '/uploads/placeholder.jpg' %>" alt="<%= post.title %>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
            </a>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <span class="text-[10px] text-accent font-bold uppercase tracking-wider">
                  <%= new Date(post.published_at).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short' }) %>
                </span>
                <h3 class="text-sm font-bold text-primary mt-2 mb-3 line-clamp-2 hover:text-primary-light">
                  <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                </h3>
                <p class="text-xs text-text-muted line-clamp-3 leading-relaxed mb-4">
                  <%= post.excerpt %>
                </p>
              </div>
              <a href="/blog/<%= post.slug %>" class="text-xs font-bold text-primary hover:text-primary-light flex items-center space-x-1 border-b border-primary hover:border-primary-light pb-0.5 self-start">
                <span>Ler Artigo</span>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-text-muted col-span-full text-center">Nenhum artigo publicado no blog.</p>
      <% } %>
    </div>
  </div>
</section>

<!-- EXIT INTENT POPUP (CRO CAPTURE, captures email for coupon) -->
<div id="exit-intent-popup" class="fixed inset-0 z-50 items-center justify-center p-4 bg-gray-900 bg-opacity-80 hidden transition-opacity duration-300 opacity-0 font-body">
  <div class="bg-white rounded-2xl border border-border shadow-2xl p-8 max-w-md w-full relative">
    <button type="button" id="close-exit-intent-btn" class="absolute top-4 right-4 text-text-muted hover:text-primary">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="text-center space-y-4">
      <div class="inline-flex p-3 bg-accent bg-opacity-10 text-accent rounded-full text-2xl mx-auto">☕</div>
      <h3 class="text-lg font-bold text-primary font-display">Não vá embora de xícara vazia!</h3>
      <p class="text-xs text-text-muted leading-relaxed">
        Cadastre-se na nossa newsletter agora e ganhe um cupom de <strong>10% de desconto</strong> para sua primeira compra!
      </p>
      
      <form id="exit-intent-form" class="space-y-3 pt-2">
        <input type="email" required placeholder="Seu melhor e-mail" class="w-full bg-surface border border-border rounded-xl px-4 py-3 text-xs focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none">
        <button type="submit" class="w-full py-3 bg-accent hover:bg-yellow-600 text-primary font-bold text-xs rounded-xl shadow-lg transition-colors">
          Quero meus 10% OFF
        </button>
      </form>
      
      <!-- coupon reward wrapper -->
      <div id="exit-intent-success" class="hidden p-4 border border-green-200 bg-green-50 text-green-800 rounded-xl space-y-2">
        <p class="text-xs font-bold">Parabéns! Use o cupom abaixo:</p>
        <span class="inline-block px-4 py-2 border-2 border-dashed border-green-400 font-extrabold font-display bg-white text-md tracking-wider">
          BEMVINDO10
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  // Exit Intent Popup scripts
  function closeExitIntentPopup() {
    const popup = document.getElementById('exit-intent-popup');
    if (popup) {
      popup.classList.add('opacity-0');
      setTimeout(() => {
        popup.classList.add('hidden');
        popup.classList.remove('flex');
      }, 300);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const closeBtn = document.getElementById('close-exit-intent-btn');
    if (closeBtn) {
      closeBtn.addEventListener('click', closeExitIntentPopup);
    }

    const popup = document.getElementById('exit-intent-popup');
    if (popup) {
      popup.addEventListener('click', function(e) {
        if (e.target === popup) {
          closeExitIntentPopup();
        }
      });
    }

    let triggered = sessionStorage.getItem('exit_intent_triggered');
    if (!triggered) {
      document.addEventListener('mouseout', function(e) {
        // Trigger when mouse moves out the top of viewport (exit intent)
        if (e.clientY < 20 && !triggered) {
          triggered = true;
          sessionStorage.setItem('exit_intent_triggered', 'true');
          
          if (popup) {
            popup.classList.remove('hidden');
            popup.classList.add('flex');
            setTimeout(() => {
              popup.classList.remove('opacity-0');
            }, 50);
          }
        }
      });
    }

    // Form logic
    const form = document.getElementById('exit-intent-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        // Mimic API subscription
        form.classList.add('hidden');
        const successDiv = document.getElementById('exit-intent-success');
        if (successDiv) {
          successDiv.classList.remove('hidden');
        }
      });
    }
  });
</script>
