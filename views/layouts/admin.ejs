<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-surface">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Painel Administrativo' %></title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
  
  <!-- Stylesheets -->
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="h-full font-body flex flex-col md:flex-row overflow-hidden">

  <!-- ADMIN SIDEBAR -->
  <aside class="w-full md:w-64 bg-primary text-white flex flex-col flex-shrink-0 z-30">
    <!-- Header/Brand -->
    <div class="px-6 py-5 border-b border-gray-800 flex items-center justify-between">
      <a href="/admin" class="flex items-center space-x-2">
        <svg class="w-6 h-6 text-accent fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H9v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        <span class="text-sm font-extrabold font-display text-white tracking-wide">Painel Admin</span>
      </a>
      <span class="px-2 py-0.5 text-[8px] font-bold uppercase tracking-wider bg-accent text-primary rounded-md">V2.0</span>
    </div>

    <!-- Navigation List -->
    <nav class="flex-grow py-6 px-4 space-y-1 overflow-y-auto">
      <a href="/admin" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z"/></svg>
        Dashboard
      </a>
      <a href="/admin/produtos" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        Produtos
      </a>
      <a href="/admin/pedidos" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
        Pedidos
      </a>
      <a href="/admin/clientes" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        Clientes
      </a>
      <a href="/admin/cupons" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
        Cupons
      </a>
      <a href="/admin/posts" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2 2v3m2-3a2 2 0 012 2v3m2-3a2 2 0 00-2 2v3M3 8h14M6 12h5m-5 4h5"/></svg>
        Blog Posts
      </a>
      
      <a href="/" class="flex items-center px-4 py-2.5 text-xs font-bold rounded-xl hover:bg-gray-800 transition-colors border-t border-gray-800 pt-6">
        <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Voltar para a Loja
      </a>
    </nav>

    <!-- Admin profile -->
    <div class="p-4 border-t border-gray-800 flex items-center space-x-3 bg-gray-950">
      <div class="w-8 h-8 rounded-full bg-accent text-primary font-bold flex items-center justify-center text-xs">
        AD
      </div>
      <div>
        <p class="text-xs font-bold truncate">Administrador</p>
        <a href="/logout" class="text-[10px] text-danger hover:underline">Sair</a>
      </div>
    </div>
  </aside>

  <!-- CONTENT CONTAINER -->
  <main class="flex-grow flex flex-col overflow-hidden bg-surface">
    <!-- Navbar / Breadcrumb header for dashboard -->
    <header class="h-16 border-b border-border bg-white px-8 flex items-center justify-between">
      <h2 class="text-sm font-extrabold text-primary font-display uppercase tracking-wider"><%= typeof title !== 'undefined' ? title : 'Painel de Controle' %></h2>
      <div class="text-xs text-text-muted">
        Modo: <span class="font-bold text-success">Produção</span>
      </div>
    </header>

    <!-- Main Dynamic Content -->
    <section class="flex-grow overflow-y-auto p-8">
      <%- body %>
    </section>
  </main>

</body>
</html>
